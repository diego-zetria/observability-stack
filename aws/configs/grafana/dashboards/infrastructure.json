        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "netdata_system_net_kilobits_persec_average{dimension=\"received\"}",
          "legendFormat": "In",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "netdata_system_net_kilobits_persec_average{dimension=\"sent\"}",
          "legendFormat": "Out",
          "range": true,
          "refId": "B"
        }
