        {
          "id": 17,
          "title": "All Operations RED Table",
          "description": "Comprehensive RED metrics across ALL span kinds (SERVER, CLIENT, INTERNAL). Use this to cross-reference server-side endpoint performance with downstream client calls. Filterable columns support ad-hoc analysis.",
