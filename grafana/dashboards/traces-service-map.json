          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "refId": "Rate",
              "expr": "sum by (span_name, span_kind) (rate(traces_spanmetrics_calls_total{service=~\"$service\"}[5m]))",
              "legendFormat": "{{span_name}} {{span_kind}}",
              "instant": true,
              "format": "table"
