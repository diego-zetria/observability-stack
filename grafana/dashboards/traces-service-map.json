                  "span_kind": 1,
                  "Value #Rate": 2,
                  "Value #ErrorRate": 3,
                  "Value #P50": 4,
                  "Value #P95": 5
                },
                "renameByName": {
                  "span_name": "Operation",
                  "span_kind": "Kind",
                  "Value #Rate": "Rate (req/s)",
                  "Value #ErrorRate": "Error %",
                  "Value #P50": "P50 (s)",
                  "Value #P95": "P95 (s)"
                }
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
