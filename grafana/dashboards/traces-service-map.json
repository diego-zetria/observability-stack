{
  "uid": "traces-service-map",
  "title": "Traces & Service Map",
  "description": "Distributed tracing: service map, trace search, RED metrics, latency distribution, and error analysis.",
  "tags": ["app-backend", "tempo", "traces", "service-map", "observability"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "7d"]
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 39,
  "version": 1,
  "links": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Tempo",
          "value": "tempo"
        },
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "name": "tempo_datasource",
        "label": "Tempo Datasource",
        "options": [],
        "query": "tempo",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "name": "prometheus_datasource",
        "label": "Prometheus Datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(traces_spanmetrics_calls_total, service)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "label": "Service",
        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(traces_spanmetrics_calls_total, service)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Health",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Spans / min",
      "description": "Total number of trace spans per minute across selected services. Reflects overall traffic volume ingested by Tempo.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=~\"$service\"}[5m])) * 60 OR vector(0)",
          "legendFormat": "spans/min",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#3B82F6", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#3B82F6", "value": null }
            ]
          },
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "description": "Percentage of spans with STATUS_CODE_ERROR out of total spans. Alert threshold: >5% is critical.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(traces_spanmetrics_calls_total{service=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum(rate(traces_spanmetrics_calls_total{service=~\"$service\"}[5m])) * 100) OR vector(0)",
          "legendFormat": "error %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Avg Latency",
      "description": "Average span duration computed from latency histogram sum/count. A rise here indicates general slowness across all operations.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(traces_spanmetrics_latency_sum{service=~\"$service\"}[5m])) / sum(rate(traces_spanmetrics_latency_count{service=~\"$service\"}[5m]))) OR vector(0)",
          "legendFormat": "avg latency",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "s",
          "decimals": 3,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "P95 Latency",
      "description": "95th percentile span duration across all operations. A leading indicator of user-facing slowness before averages degrade.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 5, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[5m]))) OR vector(0)",
          "legendFormat": "P95",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#FF9830", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "s",
          "decimals": 3,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Active Services",
      "description": "Number of distinct services currently emitting trace spans. A drop here may indicate a service has gone offline.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (service) (traces_spanmetrics_calls_total{service=~\"$service\"})) OR vector(0)",
          "legendFormat": "services",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 200,
      "title": "Service Map & RED Metrics",
      "type": "row"
    },
    {
      "id": 6,
      "title": "Service Map",
      "description": "Visual service dependency graph from Tempo span metrics. Node size reflects request rate; arc color shows success (green) vs failure (red) ratio. Click a node to filter traces.",
      "type": "nodeGraph",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 7 },
      "datasource": {
        "type": "tempo",
        "uid": "${tempo_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "${tempo_datasource}"
          },
          "queryType": "serviceMap"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "arc__success" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } },
              { "id": "displayName", "value": "Success" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "arc__failed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } },
              { "id": "displayName", "value": "Failed" }
            ]
          }
        ]
      },
      "options": {}
    },
    {
      "id": 7,
      "title": "Service RED Metrics",
      "description": "Rate, Error %, and P95 latency per server-side operation. Gauge bars reflect performance relative to thresholds. Sort by Rate to find busiest endpoints.",
      "type": "table",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "Rate",
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m]))",
          "legendFormat": "{{span_name}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "ErrorRate",
          "expr": "(sum by (span_name) (rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum by (span_name) (rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])) * 100) OR vector(0)",
          "legendFormat": "{{span_name}}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "P95",
          "expr": "histogram_quantile(0.95, sum by (span_name, le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))",
          "legendFormat": "{{span_name}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "span_name" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true
            },
            "indexByName": {
              "span_name": 0,
              "Value #Rate": 1,
              "Value #ErrorRate": 2,
              "Value #P95": 3
            },
            "renameByName": {
              "span_name": "Operation",
              "Value #Rate": "Rate (req/s)",
              "Value #ErrorRate": "Error %",
              "Value #P95": "P95 (s)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": false
          },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Operation" },
            "properties": [
              { "id": "custom.width", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Rate (req/s)" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "decimals", "value": 2 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "gradient" }
              },
              {
                "id": "color",
                "value": { "mode": "continuous-BlPu" }
              },
              { "id": "min", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 25 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "orange", "value": 5 },
                    { "color": "red", "value": 10 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "gradient" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95 (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 5 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.3 },
                    { "color": "orange", "value": 0.5 },
                    { "color": "red", "value": 2 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "gauge", "mode": "lcd" }
              }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "md",
        "showHeader": true,
        "sortBy": [{ "displayName": "Rate (req/s)", "desc": true }],
        "footer": {
          "show": true,
          "reducer": ["sum"],
          "countRows": true,
          "enablePagination": false
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 300,
      "title": "Latency Distribution",
      "type": "row"
    },
    {
      "id": 8,
      "title": "Latency Heatmap",
      "description": "Distribution of server-side span durations over time. Darker cells indicate more spans falling in that latency bucket. Use this to spot latency spikes or bi-modal distributions.",
      "type": "heatmap",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(traces_spanmetrics_latency_bucket{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "s",
          "axisPlacement": "left",
          "reverse": false,
          "decimals": 3
        },
        "rowsFrame": { "layout": "auto" },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges",
          "steps": 64,
          "exponent": 0.5,
          "fill": "dark-orange",
          "scale": "exponential"
        },
        "cellGap": 1,
        "filterValues": { "le": 1e-9 },
        "tooltip": {
          "mode": "single",
          "showColorScale": true,
          "yHistogram": true
        },
        "legend": { "show": true },
        "exemplars": { "color": "rgba(255,255,255,0.3)" }
      }
    },
    {
      "id": 9,
      "title": "Latency Percentiles",
      "description": "P50, P95, and P99 latency trends over time. P99 spikes that do not affect P50 indicate tail latency issues affecting a small fraction of requests.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "P50",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "P50"
        },
        {
          "refId": "P95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "P95"
        },
        {
          "refId": "P99",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Duration",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 400,
      "title": "Traffic & Errors",
      "type": "row"
    },
    {
      "id": 10,
      "title": "Request Rate by Operation",
      "description": "Per-operation request rate for server-side spans. Helps identify the busiest endpoints and detect traffic shifts or sudden drops that may indicate upstream problems.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m]))",
          "legendFormat": "{{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "req/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "ops",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
