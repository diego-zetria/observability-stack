    {
      "id": 9,
      "title": "Payment Latency P50/P90/P99",
      "description": "Payment processing latency percentiles over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
