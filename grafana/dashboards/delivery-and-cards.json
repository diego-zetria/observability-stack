    {
      "id": 1,
      "title": "Deliveries Today",
      "description": "Total delivery sessions created in the last 24 hours",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 20 }
            ]
          },
          "noValue": "0",
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(increase(delivery_sessions_total{action=\"created\"}[24h])) OR vector(0)",
          "legendFormat": "Deliveries",
          "instant": true,
          "refId": "A"
