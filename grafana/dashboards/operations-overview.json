      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "(sum(increase(payments_processed_total{status=\"success\"}[1h])) / sum(increase(payments_processed_total[1h]))) * 100",
