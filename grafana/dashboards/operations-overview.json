      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 50 }
            ]
          },
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
