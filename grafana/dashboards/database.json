{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "uid": "database",
  "title": "PostgreSQL - USE Method",
  "description": "PostgreSQL RDS 15.12 metrics via postgres_exporter. Organized by USE method: Utilization, Saturation, Errors.",
  "tags": ["postgresql", "database", "rds", "use-method"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {
          "selected": true,
          "text": "myapp",
          "value": "myapp"
        },
        "hide": 2,
        "includeAll": false,
        "label": "Database",
        "multi": false,
        "name": "database",
        "options": [
          {
            "selected": true,
            "text": "myapp",
            "value": "myapp"
          }
        ],
        "query": "myapp",
        "skipUrlSync": false,
        "type": "custom"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Health Overview",
      "type": "row",
      "panels": []
    },
    {
      "id": 1,
      "title": "Connection Utilization",
      "description": "Percentage of max_connections currently in use. Thresholds: green <60%, yellow 60-80%, orange 80-90%, red >90%.",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "decimals": 1,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizWidth": 75,
        "minVizHeight": 75,
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(pg_stat_activity_count{datname=\"myapp\"}) / scalar(max(pg_settings_max_connections)) * 100",
          "legendFormat": "Utilization",
          "range": true,
          "instant": false,
          "refId": "A"
        }
      ],
      "pluginVersion": "11.0.0"
    },
    {
      "id": 2,
      "title": "Cache Hit Ratio",
      "description": "Buffer cache hit ratio. Pages found in shared_buffers vs read from disk. Ideal: >=99%. Below 90% is critical.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 },
              { "color": "dark-green", "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 2,
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "nan",
                "result": {
                  "text": "N/A",
                  "color": "text"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(pg_stat_database_blks_hit{datname=~\"$database\"}) / (sum(pg_stat_database_blks_hit{datname=~\"$database\"}) + sum(pg_stat_database_blks_read{datname=~\"$database\"})) * 100",
          "legendFormat": "Cache Hit Ratio",
          "range": true,
          "instant": false,
          "refId": "A"
        }
      ],
      "pluginVersion": "11.0.0"
    },
    {
      "id": 3,
      "title": "Transactions / sec",
      "description": "Combined rate of committed and rolled-back transactions per second.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "ops",
          "decimals": 1,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(rate(pg_stat_database_xact_commit{datname=~\"$database\"}[5m])) + sum(rate(pg_stat_database_xact_rollback{datname=~\"$database\"}[5m]))",
          "legendFormat": "TPS",
          "range": true,
          "instant": false,
          "refId": "A"
        }
      ],
      "pluginVersion": "11.0.0"
    },
    {
      "id": 4,
      "title": "Database Size",
      "description": "Total size of the selected database(s) on disk.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": {
        "type": "prometheus",
