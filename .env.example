# =============================================================================
# Monitoring Stack - Environment Variables
# =============================================================================
# Copy to .env and adjust as needed:
#   cp .env.example .env

# PostgreSQL Exporter - connection string do RDS
DATABASE_URL=postgresql://user:password@your-rds-host.region.rds.amazonaws.com:5432/mydb

# Redis Exporter
REDIS_ADDR=host.docker.internal:6379
REDIS_PASSWORD=
